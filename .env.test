# Copy to project root: cp deploy/.env.example .env

# Public hostname (must point to this VPS)
DOMAIN=flags.example.com

# PostgreSQL (must match database.password in config.prod.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=guess_the_flag

# Docker image tag
IMAGE_TAG=latest

# Traefik — adjust to your existing setup
# Network Traefik uses to reach containers (docker network ls)
TRAEFIK_NETWORK=traefik
# Router / service name prefix in Traefik dashboard
TRAEFIK_ROUTER_NAME=guess-the-flag
# Entrypoint with TLS (common: websecure)
TRAEFIK_ENTRYPOINT=websecure
# certresolver name from your Traefik static config
TRAEFIK_CERT_RESOLVER=letsencrypt
