{
	"info": {
		"_postman_id": "guess-the-flag-api",
		"name": "Guess The Flag API",
		"description": "API коллекция для игры \"Угадай флаг\". Включает все эндпоинты для аутентификации и игрового процесса.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "guess-the-flag"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('jwt_token', responseJson.token);",
									"    pm.test('Token saved to environment', function () {",
									"        pm.expect(responseJson.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"testpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"register"
							]
						},
						"description": "Регистрация нового пользователя. После успешной регистрации токен автоматически сохраняется в переменной окружения."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('jwt_token', responseJson.token);",
									"    pm.test('Token saved to environment', function () {",
									"        pm.expect(responseJson.token).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"password\": \"testpassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Аутентификация пользователя. После успешного входа токен автоматически сохраняется в переменной окружения."
					},
					"response": []
				}
			],
			"description": "Эндпоинты для регистрации и аутентификации пользователей"
		},
		{
			"name": "Game",
			"item": [
				{
					"name": "Start Game",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const responseJson = pm.response.json();",
									"    pm.environment.set('game_id', responseJson.game_id);",
									"    pm.test('Game ID saved to environment', function () {",
									"        pm.expect(responseJson.game_id).to.be.a('string');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/game/start",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"game",
								"start"
							]
						},
						"description": "Начать новую игровую сессию. Game ID автоматически сохраняется для использования в других запросах."
					},
					"response": []
				},
				{
					"name": "Get Question",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"gameId\": \"{{game_id}}\",\n    \"questionNum\": 1\n}"
						},
						"url": {
							"raw": "{{base_url}}/game/question",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"game",
								"question"
							]
						},
						"description": "Получить вопрос (флаг страны) для указанного номера вопроса в игре."
					},
					"response": []
				},
				{
					"name": "Answer Question",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"gameId\": \"{{game_id}}\",\n    \"questionNum\": 1,\n    \"answer\": \"США\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/game/answer",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"game",
								"answer"
							]
						},
						"description": "Отправить ответ на вопрос и получить результат (правильно/неправильно)."
					},
					"response": []
				},
				{
					"name": "End Game",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"gameId\": \"{{game_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/game/end",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"game",
								"end"
							]
						},
						"description": "Завершить игровую сессию и получить результаты всех вопросов и ответов."
					},
					"response": []
				}
			],
			"description": "Эндпоинты для управления игровым процессом"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		}
	]
} 